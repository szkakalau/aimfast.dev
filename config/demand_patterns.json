      "pay": { "budget": 5, "urgency": 5, "_note": "预算: 设计工具有付费传统; 紧迫度: 随市场竞争加剧" }
    }
  ],
  "intersection_rules": {
    "_note": "需求交叉检测规则：当两个需求类别同时上升时，自动标记交叉机会",
    "pairs": [
      ["memory", "cost"],
      ["skills", "governance"],
      ["multi-agent", "observability"],
      ["cost", "observability"],
      ["memory", "multi-agent"]
    ]
  },
  "weights": {
    "_note": "机会指数加权系数：Trend（市场热度）+ Pain（痛感）+ Pay（付费意愿）",
    "trend": 0.35,
    "pain": 0.35,
    "pay": 0.30
  }
}
