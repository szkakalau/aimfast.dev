      "buyer_signals": ["enterprise", "team", "startup", "api key", "production", "scale", "budget", "roi", "save money"],
      "pain": { "frequency": 10, "severity": 10, "_note": "频率: 每个用AI的人都会遇到; 严重度: 直接触及利润底线" },
      "pay": { "budget": 10, "urgency": 9, "_note": "预算: 企业有明确的成本优化预算; 紧迫度: 每月账单驱动" }
