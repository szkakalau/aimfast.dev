      "pain": { "frequency": 5, "severity": 3, "_note": "频率: 新用户常遇到; 严重度: 随时间自然解决" },
      "pay": { "budget": 2, "urgency": 2, "_note": "预算: 教育类付费意愿低; 紧迫度: 免费资源充足" }
    },
    {
      "id": "ux",
      "name": "AI 交互体验 / UI",
      "name_en": "AI UX & Interface",
      "description": "AI 工具的交互界面、用户体验优化",
      "keywords": ["ui", "ux", "interface", "chat", "conversation", "terminal", "cli", "gui", "vscode", "editor", "ide", "web", "app", "mobile", "desktop", "dashboard", "visual", "design", "frontend"],
      "pain_signals": ["ugly", "hard to use", "clunky", "confusing", "overwhelming", "complex ui", "too many button"],
      "buyer_signals": ["enterprise", "team", "startup", "designer", "pm", "product"],
