{
  "_schema": "需求模式定义 v2.0 — 三级评分：基础属性 + 市场热度 + 增长速度",
  "_version": "2.0",
  "_scoring_formula": "Opportunity = (0.35 × TrendScore + 0.35 × PainScore + 0.30 × PayScore) × GrowthModifier",
  "_note": "Pain = frequency × severity / 10, Pay = budget × urgency / 10, Trend = appearances/max × 10, Growth = 1.2(rising)/1.0(stable)/0.8(falling)",
  "categories": [
    {
      "id": "memory",
