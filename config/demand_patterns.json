      "keywords": ["mem", "memory", "remember", "context", "long-term", "persistent", "recall", "history", "stateful", "session", "knowledge-base", "rag", "vector", "embedding", "chroma", "pinecone", "qdrant"],
      "pain_signals": ["lose context", "forget", "reset", "lost memory", "context window", "no memory", "can't remember", "amnesia"],
      "buyer_signals": ["enterprise", "team", "company", "startup", "paid", "subscription", "pro", "business"],
      "pain": { "frequency": 8, "severity": 8, "_note": "频率: 上下文丢失是高频痛点; 严重度: 直接导致Agent不可用" },
      "pay": { "budget": 7, "urgency": 7, "_note": "预算: 企业愿意为可靠性付费; 紧迫度: 影响开发效率" }
