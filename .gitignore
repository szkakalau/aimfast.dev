# 原始信号数据（每日采集，量大且有时效性）——仅本地保存
raw/

# 日志文件
logs/

# 日报输出（本地归档，不需要版本控制）
# 例外：signals.json 是 track_recurring 跨日期检测的输入，CI fresh checkout 时
# 需要历史信号，故提交 signals.json；其余日报产物仍仅本地保存。
daily/**
!daily/*/
!daily/*/signals.json

# 周报输出（本地归档，不需要版本控制）
weekly/

# Python
__pycache__/
*.pyc
.venv/
venv/

# IDE
.vscode/
.idea/

# Landing Page（旧目录，已迁移至 public/）
landing_pages/

# Playwright 测试
.playwright-mcp/
lp-*.png

# 环境变量（LLM API Key 等）
.env
.env.local

