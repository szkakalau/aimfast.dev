  "scoring": {
    "formula": "Score = cross_platform×3 + volume×2 + freshness×2 + actionability×2 + buyer_clarity×1 + consumer_appeal×2 + problem_clarity×2",
    "weights": {
      "cross_platform": 3,
      "volume": 2,
      "freshness": 2,
      "actionability": 2,
      "buyer_clarity": 1,
      "consumer_appeal": 2,
      "problem_clarity": 2
    },
    "thresholds": {
      "action_trigger": 17,
      "cross_platform_min": 2
    },
    "rubrics": {
      "cross_platform": {
        "1_platform": 1,
        "2_platforms": 3,
        "3_plus_platforms": 5
      },
      "volume": {
        "lt_50": 1,
        "50_200": 2,
        "200_500": 3,
        "gt_500": 5
      },
      "freshness": {
        "today": 5,
        "yesterday": 3,
        "3_days_plus": 1
      },
      "actionability": {
        "concrete_product_with_pricing": 5,
        "vague_direction": 3,
        "pure_complaint": 1
      },
      "buyer_clarity": {
        "specific_buyer": 5,
        "likely_buyer": 3,
        "unknown_buyer": 1
      },
      "consumer_appeal": {
        "strong_c_end": 5,
        "mixed_audience": 3,
        "developer_only": 1
      },
      "problem_clarity": {
        "clear_pain_point": 5,
        "likely_pain": 4,
        "possible_pain": 3,
        "mixed_signal": 2,
        "likely_hype": 1,
        "neutral": 2
      }
    }
  },
  "decay": {
    "3_days_same_topic": 0.5,
    "5_days_archive": true,
    "cooling_threshold_months": 3
  },
  "schedule": {
    "collect": "08:00",
    "process": "08:30",
    "report": "09:00",
    "action_plan": "09:30",
    "article": "09:45",
    "push": "10:00",
    "publish_article": "10:30",
    "tracking_update": "14:00",
    "weekly_review": "Sunday 20:00"
  },
  "distribution": {
    "local_archive": true,
    "planet_article": {
      "enabled": false,
      "auto_publish": false,
      "note": "手动审核后发布，保证质量"
    },
    "wechat_mp": {
      "enabled": false,
      "note": "预留"
    }
  },
  "landing_page": {
    "domain": "aimfast.dev",
    "platform": "Vercel",
    "framework": "Next.js",
    "verification_days": 7,
    "thresholds": {
      "success": {
        "uv": 100,
        "has_signup": true
      },
      "fail": {
        "uv": 30
      },
      "adjust": {
        "uv_min": 30,
        "uv_max": 100,
        "condition": "zero_signups"
      }
    }
  },
  "llm": {
    "provider": "DeepSeek",
    "model": "deepseek-chat",
    "monthly_budget_usd": 20,
    "_api_key_note": "API key 仅通过环境变量 DEEPSEEK_API_KEY 配置，请勿在此填写"
  },
  "enrichment": {
    "_comment": "/last30days 社区语境丰富 — 对当日 Top 信号运行社区研究引擎",
    "enabled": true,
    "engine_path": "auto",
    "python_path": "auto",
    "max_signals": 2,
    "min_score": 20,
    "timeout_per_signal_s": 180,
    "max_items": 15,
    "memory_dir": "~/Documents/Last30Days"
  },
  "content": {
    "planet_article": {
      "type_distribution": {
        "opportunity_deep_dive": 0.4,
        "counter_intuitive": 0.25,
        "methodology": 0.2,
        "trend_alert": 0.1,
        "failure_postmortem": 0.05
      },
      "max_consecutive_same_type": 2,
      "title_max_chars": 30,
      "word_count_range": [
        2000,
        4000
      ]
    },
    "daily_report": {
      "word_count_range": [
        1500,
        3000
      ],
      "reading_time_minutes": 5
    }
  },
