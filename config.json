{
  "_comment": "AimFast.Dev — 配置文件 | 版本 v2.2 — 新增 problem_clarity 维度",
  "api_keys": {
    "producthunt": {
      "client_id": "YOUR_PH_CLIENT_ID",
      "client_secret": "YOUR_PH_CLIENT_SECRET"
    }
  },
  "project": {
    "name": "AimFast.Dev",
    "timezone": "Asia/Shanghai",
    "language": "zh-CN"
  },
  "signals": {
    "overseas": [
      {
        "name": "Hacker News",
        "key": "hn",
